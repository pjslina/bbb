# ============================================================
# Agent Service - Environment Variables Template
# Copy to .env and fill in real values
# ============================================================

# ----- App -----
APP_NAME=single-agent
APP_ENV=development           # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR

# ----- LLM (OpenAI-compatible) -----
LLM_PROVIDER=qwen             # qwen | glm | openai
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=qwen-plus
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=60                # seconds

# ----- Redis -----
# Redis 部署模式: standalone | cluster | sentinel
REDIS_MODE=standalone

# ===== 单机模式 (REDIS_MODE=standalone) =====
# 格式: redis://host:port/db
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=20

# ===== 集群模式 (REDIS_MODE=cluster) =====
# 格式: host1:port1,host2:port2,host3:port1 (逗号分隔)
# REDIS_CLUSTER_NODES=192.168.1.10:6379,192.168.1.11:6379,192.168.1.12:6379
# 集群模式下的密码 (如果有)
REDIS_CLUSTER_PASSWORD=

# ===== Sentinel 模式 (REDIS_MODE=sentinel) =====
# Sentinel 服务地址，多个用逗号分隔
# REDIS_SENTINEL_NODES=192.168.1.10:26379,192.168.1.11:26379,192.168.1.12:26379
# Sentinel 认证密码 (如果有)
REDIS_SENTINEL_PASSWORD=
# Master 名称 (Sentinel配置中的主节点名称)
REDIS_MASTER_NAME=mymaster

# ===== 通用配置 =====
SESSION_TTL=86400             # seconds (24h)
SUMMARY_THRESHOLD=20          # messages before summarize

# ----- PostgreSQL (Primary) -----
PG_PRIMARY_DSN=postgresql+asyncpg://user:password@localhost:5432/agentdb
PG_PRIMARY_POOL_SIZE=10
PG_PRIMARY_MAX_OVERFLOW=20

# ----- PostgreSQL (Secondary - optional) -----
PG_SECONDARY_DSN=postgresql+asyncpg://user:password@localhost:5433/agentdb_replica
PG_SECONDARY_POOL_SIZE=5

# ----- OpenGauss (optional) -----
OG_PRIMARY_DSN=postgresql+asyncpg://gaussdbuser:password@localhost:5432/gaussdb
OG_PRIMARY_POOL_SIZE=10
OG_SECONDARY_DSN=

# ----- Agent Safety -----
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT=120             # seconds
AGENT_MAX_TOOL_CALLS=5